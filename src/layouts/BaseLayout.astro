---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  articleDate?: string;
}

const { 
  title, 
  description = "Founder, Kyrah Design Studio | Architect & Interior Designer crafting thoughtful luxury homes in Bengaluru.", 
  ogImage = "/og-fallback.png",
  articleDate 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://rishikamiranda.com');
---
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content={articleDate ? "article" : "website"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, canonicalURL.origin)} />
    {articleDate && <meta property="article:published_time" content={articleDate} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, canonicalURL.origin)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  
  <body class="bg-stone-50 text-stone-900 antialiased font-sans selection:bg-stone-200 min-h-screen flex flex-col">
    
    <header class="max-w-2xl mx-auto w-full px-6 py-10 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <a href="/" class="font-bold text-lg tracking-tight text-stone-900 hover:text-stone-600 transition">
        Rishika Miranda
      </a>
      <nav class="flex gap-6 text-sm font-medium text-stone-500">
        <a href="/blog" class="hover:text-stone-900 transition">blog</a>
        <a href="/about" class="hover:text-stone-900 transition">about</a>
        <a href="/contact" class="hover:text-stone-900 transition">contact</a>
      </nav>
    </header>
    
    <main class="max-w-2xl mx-auto w-full px-6 py-6 flex-1">
      <slot />
    </main>

    <footer class="max-w-2xl mx-auto w-full px-6 py-12 border-t border-stone-200 text-xs text-stone-400 text-center">
      &copy; {new Date().getFullYear()} Rishika Miranda. Built with Astro & Tailwind CSS.
    </footer>
  </body>
</html>