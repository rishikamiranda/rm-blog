---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  articleDate?: string;
}

const { 
  title, 
  description = "Founder, Kyrah Design Studio | Architect & Interior Designer crafting thoughtful luxury homes in Bengaluru.", 
  ogImage = "/og-fallback.png",
  articleDate 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://rishikamiranda.com');
---
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  
  <body class="bg-paper text-ink font-mono antialiased min-h-screen flex flex-col relative">
    <div class="relative z-10 flex flex-col min-h-screen w-full">
      
      <!-- NAVIGATION - Stretched to match screenshot margins -->
      <nav class="w-full flex items-center justify-between px-8 md:px-16 py-6 border-b border-warm">
        <a 
          href="/" 
          class="font-display font-medium text-xl tracking-tight text-ink hover:text-orange transition-colors duration-200 italic" 
          aria-label="Rishika Miranda Home"
        >
          RishikaMiranda
        </a>
        
        <ul class="flex gap-8 md:gap-10 text-xs tracking-widest uppercase text-muted font-bold">
          <li><a href="/blog" class="hover:text-ink transition">Journal</a></li>
          <li><a href="/category/projects" class="hover:text-ink transition">Projects</a></li>
          <li><a href="/category/events" class="hover:text-ink transition">Events</a></li>
          <li><a href="/category/resources" class="hover:text-ink transition">Resources</a></li>
          <li><a href="/about" class="hover:text-ink transition">About</a></li>
        </ul>
      </nav>
      
      <!-- MAIN CANVAS - Completely flat and open layout -->
      <main class="w-full flex-1 flex flex-col">
        <slot />
      </main>

      <!-- FOOTER - Boundless alignment block -->
      <footer class="w-full border-t border-warm px-8 md:px-16 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mt-auto">
        <div class="text-xs text-muted tracking-widest">
          &copy; {new Date().getFullYear()} — Rishika Miranda. All rights reserved.
        </div>
        
        <div class="flex items-center gap-6 text-xs tracking-widest uppercase text-muted font-bold">
          <a href="https://kyrah.in" target="_blank" rel="noopener noreferrer" class="hover:text-orange transition">kyrah.in</a>
          <a href="https://www.linkedin.com/in/rishika-miranda-163260329/" target="_blank" rel="noopener noreferrer" class="hover:text-orange transition">linkedin</a>
          <a href="https://www.instagram.com/rishikamiranda/" target="_blank" rel="noopener noreferrer" class="hover:text-orange transition">instagram</a>
        </div>
      </footer>
    </div>
  </body>
</html>